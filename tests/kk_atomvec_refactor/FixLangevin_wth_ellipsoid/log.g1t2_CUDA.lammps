KOKKOS mode with Kokkos version 5.0.0 is enabled
  using double precision
  using view layout = default
  will use up to 1 GPU(s) per node
  using 2 OpenMP thread(s) per MPI task
package kokkos
###
# Box and units  (use LJ units and periodic boundaries)
###

units           lj
atom_style      hybrid bond ellipsoid
WARNING: Atom style hybrid defines both, per-type and per-atom masses; both must be set, but only per-atom masses will be used (src/atom_vec_hybrid.cpp:132)
dimension	    3
boundary	    p p p
#newton 		    on

lattice		    diamond 0.01
Lattice spacing in x,y,z = 9.2831777 9.2831777 9.2831777
region		    box block 0 10 0 10 0 10
create_box	    2 box bond/types 1 extra/bond/per/atom 2
Created orthogonal box = (0 0 0) to (92.831777 92.831777 92.831777)
  1 by 1 by 1 MPI processor grid
#create_box      2 box

###################################################################
# Create Atoms in empty space
#
region         lower block 1 9 1 9 1 3
create_atoms   1 region lower
Created 1235 atoms
  using lattice units in orthogonal box = (0 0 0) to (92.831777 92.831777 92.831777)
  create_atoms CPU = 0.015 seconds
region         upper block 1 9 1 9 7 9
create_atoms   1 region upper
Created 1235 atoms
  using lattice units in orthogonal box = (0 0 0) to (92.831777 92.831777 92.831777)
  create_atoms CPU = 0.011 seconds

###################################################################
# Create Polymers
#
variable N        equal 30   # Number of beads per polymer
variable Ny_val   equal 4    # Number of polymers placed in y
variable Ny       loop ${Ny_val}
variable Ny       loop 4
variable Nz       loop 3     # Number of polymers placed in z
variable dbead    equal 0.2  # Distance Between Beads
variable step     equal 1    # Step size for loop

# Initialise the first bead
variable x0 equal 1.0
variable y0 equal 1.0
variable z0 equal 2.0

# Create the remaining beads
label loop_z
label loop_y
label loop_bead
if "${step} > ${N}" then "jump SELF end_inner"
    variable x equal ${x0} + ${dbead}
    variable x equal 1 + ${dbead}
    variable x equal 1 + 0.2
    variable y equal ${y0} + 1.5*${Ny}
    variable y equal 1 + 1.5*${Ny}
    variable y equal 1 + 1.5*1
    variable z equal ${z0} + 1.5*${Nz}
    variable z equal 2 + 1.5*${Nz}
    variable z equal 2 + 1.5*1
    create_atoms 2 single ${x} ${y} ${z}
    create_atoms 2 single 1.2 ${y} ${z}
    create_atoms 2 single 1.2 2.5 ${z}
    create_atoms 2 single 1.2 2.5 3.5
